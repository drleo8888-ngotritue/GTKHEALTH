# Sao chép file này thành .env và điền các giá trị thực

# Đường dẫn đến file local_data.db của ứng dụng chính (máy Hub)
# Windows thường là: C:\Users\<USERNAME>\AppData\Roaming\GoertekVinaCare Smart Medical\local_data.db
DB_PATH=C:\Users\ADMIN\AppData\Roaming\GoertekVinaCare Smart Medical\local_data.db

# Cổng portal web (khuyến nghị: 4000)
PORT=4000

# JWT secret - thay bằng chuỗi ngẫu nhiên dài ít nhất 32 ký tự
JWT_SECRET=thay_bang_chuoi_bi_mat_cua_ban_o_day_it_nhat_32_ky_tu

# Thời hạn JWT token (ví dụ: 8h, 1d, 7d)
JWT_EXPIRES_IN=8h

# Mật khẩu mặc định cấp cho nhân viên lần đầu (sẽ bị ép đổi)
DEFAULT_PASSWORD=Goertek@2024

# Google Gemini API Key - lấy tại https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Tên công ty (hiển thị trên giao diện)
COMPANY_NAME=Goertek Vina
